# Analytics Configuration
# Copy this file to .env.local and fill in your actual tracking IDs

# Google Tag Manager Container ID
# Find this in your GTM account - format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 Measurement ID
# Find this in your GA4 property settings - format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Reddit Pixel ID
# Find this in your Reddit Ads account - format: t2_xxxxxxxxx or a2_xxxxxxxxx
NEXT_PUBLIC_REDDIT_PIXEL_ID=REDDIT_PIXEL_XXXXXXX
